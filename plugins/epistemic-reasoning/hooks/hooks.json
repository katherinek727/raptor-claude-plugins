{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "jq -n --rawfile content ${CLAUDE_PLUGIN_ROOT}/epistemic-reasoning.md '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": $content}}'"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-protocol.sh"
      }
    ]
  }
}
